# Infrastructure
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://postgres:your_password@/novatutor?host=/cloudsql/YOUR_PROJECT:YOUR_REGION:YOUR_INSTANCE

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GCP_CLIENT_EMAIL=your_gcp_client_email
GCP_PRIVATE_KEY=your_gcp_private_key

# Providers
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY_SECRET=gemini-api-key

# Auth
JWT_SECRET=replace_with_min_32_char_secret

# Runtime
RUN_MIGRATIONS_ON_STARTUP=false
FRONTEND_ORIGINS=http://localhost:3000,https://novatutor-frontend-qz2gdtaatq-uc.a.run.app,https://novatutor-frontend-366729322781.us-central1.run.app
